generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name String?
  email     String         @unique
  role      Role           @default(USER)
  createdAt DateTime       @default(now()) @map("created_at")
  orders    Order[]
  wishlist  WishlistItem[]

  @@map("profiles")
}

model GlobalSetting {
  key   String @id
  value String

  @@map("global_settings")
}

model Product {
  id                   Int                @id @default(autoincrement())
  peach_number         Int                @unique
  title                String
  subtitle             String
  tagline              String
  brand                String             @default("tsgabrielle®")
  short_description    String
  long_description     String
  base_sku             String             @unique
  base_mpn             String             @unique
  base_gtin            String?
  product_type         String
  catalogue_category   String
  catalogue_collection String
  google_category_id   String
  google_category_name String
  gs_condition         String             @default("New")
  gs_availability      String             @default("In Stock")
  gs_gender            String?
  gs_age_group         String?
  gs_size_system       String?
  seo_meta_title       String
  seo_meta_description String
  seo_tags             String[]
  hs_code_primary      String
  hs_code_alt          String?
  shipping_tier        String
  lead_time            String
  warehouse_zone       String
  country_of_origin    String
  certifications       String[]
  traceability         String
  ethical_audit        String
  carbon_footprint     String
  msrp_display         String
  map_policy           String?
  wholesale_price      String?
  seasonality_code     String?
  landed_cost_est      String?
  url_amazon           String?
  url_etsy             String?
  url_tiktok           String?
  composition          String
  finish               String
  care_instructions    String
  prop65_status        String
  trademark_notes      String
  safety_testing       String
  warranty_info        String
  contact_info         String
  media_primary_url    String?
  media_primary_alt    String?
  media_gallery_urls   String[]
  media_gallery_alts   String[]
  status               String             @default("active")
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  gallery_slides       GallerySlide[]
  order_items          OrderItem[]
  metafields           ProductMetafield[]
  pillars              ProductPillar[]
  variants             ProductVariant[]
  wishlist_items       WishlistItem[]

  @@map("products")
}

model ProductVariant {
  id           Int     @id @default(autoincrement())
  product_id   Int
  size_label   String
  color        String
  variant_sku  String  @unique
  variant_mpn  String  @unique
  variant_gtin String?
  height       String
  diameter     String
  dim_weight   String?
  msrp         String
  inventory    String  @default("In Stock")
  sort_order   Int     @default(0)
  product      Product @relation(fields: [product_id], references: [id])

  @@map("product_variants")
}

model ProductPillar {
  id         Int     @id @default(autoincrement())
  product_id Int
  sort_order Int
  title      String
  body       String
  product    Product @relation(fields: [product_id], references: [id])

  @@map("product_pillars")
}

model GallerySlide {
  id           Int     @id @default(autoincrement())
  product_id   Int
  sort_order   Int
  label        String
  caption      String
  sub_caption  String
  accent_color String
  image_url    String?
  image_alt    String?
  bg_gradient  String?
  product      Product @relation(fields: [product_id], references: [id])

  @@map("gallery_slides")
}

model ProductMetafield {
  id         Int     @id @default(autoincrement())
  product_id Int
  key        String
  value      String
  is_public  Boolean @default(true)
  product    Product @relation(fields: [product_id], references: [id])

  @@map("product_metafields")
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String?     @db.Uuid
  total_amount    Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  paypal_order_id String?     @unique
  created_at      DateTime    @default(now())
  items           OrderItem[]
  profile         Profile?    @relation(fields: [user_id], references: [id])

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String  @db.Uuid
  product_id Int
  quantity   Int
  price      Decimal @db.Decimal(10, 2)
  order      Order   @relation(fields: [order_id], references: [id])
  product    Product @relation(fields: [product_id], references: [id])

  @@map("order_items")
}

model WishlistItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  product_id Int
  created_at DateTime @default(now())
  product    Product  @relation(fields: [product_id], references: [id])
  profile    Profile  @relation(fields: [user_id], references: [id])

  @@unique([user_id, product_id])
  @@map("wishlist_items")
}

model StoreConfig {
  id             Int      @id @default(1)
  site_settings  Json?
  hero_banner    Json?
  about_page     Json?
  navigation     Json?
  footer         Json?
  theme_design   Json?
  checkout_logic Json?
  seo_analytics  Json?
  notifications  Json?
  updated_at     DateTime @updatedAt

  @@map("store_configs")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  image_url   String?
  image_alt   String?
  sort_order  Int      @default(0)
  seo_title   String?
  seo_desc    String?
  is_active   Boolean  @default(true)
  is_featured Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("categories")
}

model Collection {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  image_url   String?
  image_alt   String?
  badge       String?
  start_date  DateTime?
  end_date    DateTime?
  sort_order  Int       @default(0)
  is_active   Boolean   @default(true)
  is_featured Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("collections")
}

model CMSPage {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  body       String
  is_visible Boolean  @default(true)
  seo_title  String?
  seo_desc   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  layout     String   @default("standard")

  @@map("cms_pages")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}
